# ============================================================================
# .env.local.example — העתק לקובץ .env.local ומלא ערכים אמיתיים
# ============================================================================

# ───── Supabase ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ───── SMS / OTP (יתווסף בשלב 7) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# חלופה ישראלית:
INFORU_USERNAME=
INFORU_API_TOKEN=

# ───── סליקה (יתווסף בשלב 8) ─────
MESHULAM_API_KEY=
MESHULAM_PAGE_CODE=
MESHULAM_USER_ID=
# חלופה:
CARDCOM_TERMINAL=
CARDCOM_USERNAME=

# ───── מידע כללי ─────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEPOSIT_AMOUNT=2000
ONLINE_DISCOUNT=30000
