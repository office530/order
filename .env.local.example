# ============================================================================
# .env.local.example — העתק לקובץ .env.local ומלא ערכים אמיתיים
# ============================================================================

# ───── Supabase ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ───── SMS / OTP ─────
# בחירת ספק:
#   1. אם לא מוגדר כלום → console (מדפיס לטרמינל, עובד מחוץ לקופסה)
#   2. אם מוגדרים INFORU_USERNAME + INFORU_API_TOKEN → inforu (מומלץ לישראל)
#   3. אם מוגדרים TWILIO_* → twilio
#   4. ניתן לאלץ בעזרת SMS_PROVIDER=console|twilio|inforu
SMS_PROVIDER=

# Inforu (מומלץ לישראל — זול יותר, אין latency בינלאומי)
INFORU_USERNAME=
INFORU_API_TOKEN=
INFORU_SENDER=RNVT

# Twilio (תומך גלובלית — שימושי לסביבת בדיקות בינלאומית)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ───── סליקה ─────
# בחירת ספק:
#   1. אם לא מוגדר כלום → mock (מסמן הזמנה כשולמה ועובר ל-/success מיידית)
#   2. אם מוגדרים MESHULAM_* → meshulam
#   3. אם מוגדרים CARDCOM_* → cardcom
#   4. ניתן לאלץ בעזרת PAYMENT_PROVIDER=mock|meshulam|cardcom
PAYMENT_PROVIDER=

# Meshulam Grow (createPaymentProcess)
MESHULAM_USER_ID=
MESHULAM_PAGE_CODE=
MESHULAM_API_KEY=
MESHULAM_TEST=1

# CardCom (LowProfile v11)
CARDCOM_TERMINAL=
CARDCOM_USERNAME=
CARDCOM_API_PASSWORD=

# ───── מידע כללי ─────
# חשוב — כתובת בסיס לבניית return/webhook URLs כשעוברים לסליקה אמיתית
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEPOSIT_AMOUNT=2000
ONLINE_DISCOUNT=30000
